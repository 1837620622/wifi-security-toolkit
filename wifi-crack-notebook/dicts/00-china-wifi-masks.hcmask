!@#$%^&*,?1,?u?l?l?l?l?l?d?1
!@#$%^&*,?1,?u?l?l?l?l?l?d?d?1
!@#$%^&*,?1,?u?l?l?l?l?l?l?d?1
!@#$%^&*,?1,?u?l?l?l?l?d?d?d?1
